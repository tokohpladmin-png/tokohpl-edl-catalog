# Public WhatsApp number in international format without +
NEXT_PUBLIC_VARINDO_WHATSAPP=6281288885224

# Zoho Books integration for live Lamitak products
# Keep these empty for local starter/demo data. Fill them in on Hostinger when ready.
ZOHO_BOOKS_ORGANIZATION_ID=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Optional. Change only if your Zoho account is not using the global .com data center.
# Examples: https://accounts.zoho.com, https://accounts.zoho.com.au, https://accounts.zoho.eu
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
ZOHO_BOOKS_BASE_URL=https://www.zohoapis.com/books/v3

# Optional. The catalog fetches active items whose Zoho item name contains this term.
ZOHO_EDL_SEARCH_TERM=EDL

# Optional cache duration for Zoho products in milliseconds.
# 86400000 = 24 hours. This supports automatic daily refresh from Zoho Books.
ZOHO_PRODUCTS_CACHE_TTL_MS=86400000

# Fetch all active Zoho Books items first, then filter Lamitak locally. Recommended for Varindo because Lamitak has many items.
ZOHO_FETCH_ALL_ACTIVE_ITEMS=true
ZOHO_MAX_PAGES=20

# Promo Items collection: active Lamitak items with Zoho Books Stock on Hand >= this number.
ZOHO_PROMO_MIN_STOCK_ON_HAND=10

# Public catalog prices are calculated from Zoho Books rate + PPN.
NEXT_PUBLIC_PPN_RATE=0.11

# Contact form email settings. Required for the enquiry form to send emails.

# Used to search uploaded image public IDs and match by numeric design code.
